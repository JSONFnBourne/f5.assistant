[Unit]
Description=Ollama LLM Service (user-level)
Documentation=https://github.com/ollama/ollama
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/ollama serve
Environment="PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin"
# Loopback only — the webapp and pipeline talk to it over localhost. Matches
# the platform's localhost-only posture; never expose 11434 to the LAN.
Environment="OLLAMA_HOST=127.0.0.1:11434"
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
